{
  "name": "clerk-chrome-extension",
  "displayName": "Clerk chrome extension",
  "version": "0.0.1",
  "description": "plasmo example",
  "author": "srushti",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@clerk/chrome-extension": "^2.2.15",
    "@clerk/clerk-react": "^5.25.2",
    "plasmo": "0.90.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "tailwindcss": "^4.0.14",
    "typescript": "5.3.3"
  },
  "manifest": {
  "key": "$CRX_PUBLIC_KEY",
  "permissions": ["cookies", "storage", "activeTab", "scripting"],
  "host_permissions": ["https://*.linkedin.com/*"],
  "background": {
    "service_worker": "background.ts"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["/src/content.tsx"],
      "run_at": "document_idle"
    }
  ]
}
}
