{
  "name": "clerk-chrome-extension",
  "displayName": "Clerk chrome extension",
  "version": "0.0.1",
  "description": "plasmo example",
  "author": "srushti",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@clerk/chrome-extension": "^2.2.15",
    "@clerk/clerk-react": "^5.25.2",
    "plasmo": "0.90.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "tailwindcss": "^4.0.14",
    "typescript": "5.3.3"
  },
  "manifest": {
    "key": "$CRX_PUBLIC_KEY",
    "permissions": [
      "cookies",
      "storage",
      "activeTab",
      "scripting"
    ],
    "host_permissions": [
      "http://localhost/*",
      "https://*.linkedin.com/*",
      "$PLASMO_PUBLIC_CLERK_SYNC_HOST/*",
      "$CLERK_FRONTEND_API/*"
    ],
    "background": {
      "service_worker": "background.ts"
    },
    "content_scripts": [
      {
        "matches": [
          "https://*.linkedin.com/*"
        ],
        "js": [
          "/src/content.tsx"
        ],
        "run_at": "document_idle"
      }
    ]
  },
  "packageManager": "pnpm@10.2.1+sha512.398035c7bd696d0ba0b10a688ed558285329d27ea994804a52bad9167d8e3a72bcb993f9699585d3ca25779ac64949ef422757a6c31102c12ab932e5cbe5cc92"
}
